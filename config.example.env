# ============================================================================
# Delta Exchange TESTNET credentials — template
# ============================================================================
# Each bot loads its OWN env file so the two strategies trade on SEPARATE testnet
# accounts (isolated balance + position). Copy this file twice:
#
#   cp config.example.env .env.smc        # SMC bot   -> BTCUSD 4h
#   cp config.example.env .env.propfirm   # PropFirm  -> ETHUSD 2h
#
# Then paste each account's TESTNET api key/secret. NEVER commit the .env* files.
# Why separate accounts: Delta nets one position per product per account. Using
# two keys keeps each bot's risk, balance and PnL cleanly isolated.
#
# On AWS: whitelist the box's ELASTIC IP on BOTH testnet API keys.
# Base URL for Delta India testnet:
#   https://cdn-ind.testnet.deltaex.org
# ----------------------------------------------------------------------------

DELTA_BASE_URL=https://cdn-ind.testnet.deltaex.org
DELTA_API_KEY=your_testnet_api_key_here
DELTA_API_SECRET=your_testnet_api_secret_here

# Symbol per bot:  .env.smc -> BTCUSD   |   .env.propfirm -> ETHUSD
DELTA_SYMBOL=BTCUSD

# Risk per trade (% of balance) and leverage cap.
RISK_PER_TRADE_PCT=1.0
MAX_LEVERAGE=5
